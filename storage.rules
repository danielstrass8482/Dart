// Storage Rules für darttrainer-app
// In Firebase Console → Storage → Rules eintragen
// oder via: firebase deploy --only storage

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /dart_voice/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /dart_voice_el/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /dart_video_sessions/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    match /dart_photos/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
