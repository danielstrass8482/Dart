// Firestore Rules für darttrainer-app
// In Firebase Console → Firestore → Rules eintragen
// oder via: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /dart_games/{doc} {
      allow read, write: if request.auth != null;
    }

    match /dart_players/{doc} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        (resource == null ||
         resource.data.userId == request.auth.uid ||
         resource.data.userId == null);
    }

    match /dart_rooms/{doc} {
      allow read, write: if request.auth != null;
    }

    match /dart_coach_analyses/{doc} {
      allow read, write: if request.auth != null;
    }

    match /dart_config/{doc} {
      allow read: if request.auth != null;
      allow write: if false; // Nur Admin/Functions schreiben
    }

    match /dart_usage/{doc} {
      allow read: if request.auth != null &&
        doc.matches(request.auth.uid + '_.*');
      allow write: if false; // Nur Functions schreiben
    }

    match /dart_video_sessions/{doc} {
      allow read, write: if request.auth != null;
    }

    match /dart_tournaments/{doc} {
      allow read, write: if request.auth != null;
    }

    match /dart_users/{userId}/{document=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

  }
}
