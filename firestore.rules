rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fuelofit - alle bestehenden Collections
    // unverändert erlaubt
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
    
    // DartTrainer - spezifische Einschränkungen
    match /dart_config/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /dart_usage/{doc} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
